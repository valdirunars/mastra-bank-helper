# Ollama (default) — model must exist locally: ollama pull qwen2.5:7b-instruct
# BANK_AGENT_MODEL=qwen2.5:7b-instruct

# Optional: force Icelandic scraper PDFs (default picks locale from model name)
# BANK_SCRAPER_LOCALE=is

# Google Gemini — only if you switch bank-agent-model.ts away from Ollama
# GOOGLE_GENERATIVE_AI_API_KEY=your-api-key
