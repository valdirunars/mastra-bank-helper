{
  "name": "mastra-bank-helper",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "mastra dev",
    "build": "mastra build",
    "start": "mastra start",
    "scrape:install": "python3 -m venv .venv && .venv/bin/pip install -r scrapers/requirements.txt",
    "scrape": ".venv/bin/python -m scrapers",
    "scrape:quotes": ".venv/bin/python -m scrapers --scraper quotes",
    "scrape:config": ".venv/bin/python -m scrapers --config scrapers/config.example.json",
    "scrape:arion": ".venv/bin/python -m scrapers --config scrapers/config.arion.json --output json --output-file .scraper-output/arion.is.json",
    "scrape:arion:en": ".venv/bin/python -m scrapers --config scrapers/config.arion.en.json --output json --output-file .scraper-output/arion.en.json",
    "scrape:landsbankinn": ".venv/bin/python -m scrapers --config scrapers/config.landsbankinn.json --output json --output-file .scraper-output/landsbankinn.is.json",
    "scrape:landsbankinn:en": ".venv/bin/python -m scrapers --config scrapers/config.landsbankinn.en.json --output json --output-file .scraper-output/landsbankinn.en.json",
    "scrape:all": "npm run scrape:arion && npm run scrape:arion:en && npm run scrape:landsbankinn && npm run scrape:landsbankinn:en"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.2",
    "@mastra/core": "^1.47.0",
    "@mastra/duckdb": "^1.5.0",
    "@mastra/evals": "^1.5.0",
    "@mastra/libsql": "^1.14.2",
    "@mastra/loggers": "^1.2.0",
    "@mastra/memory": "^1.21.2",
    "@mastra/observability": "^1.15.2",
    "ai": "^7.0.4",
    "ai-sdk-ollama": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "mastra": "^1.16.0",
    "typescript": "^6.0.3"
  }
}
